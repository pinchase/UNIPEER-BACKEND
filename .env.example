# Copy this file to .env and update values as needed
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_URL=sqlite:///db.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (Resend)
# In production, set RESEND_API_KEY and a verified sender address in DEFAULT_FROM_EMAIL.
# Example sender: no-reply@yourdomain.com
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=UniPeer <noreply@mail.unipeer.me>
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
